{
  "label": "logout",
  "action": "gnome-session-quit --logout --no-prompt",
  "text": "Logout",
  "keybind": "e"
},
{
  "label": "lock",
  "action": "loginctl lock-session",
  "text": "Lock",
  "keybind": "l"
},
{
  "label": "reboot",
  "action": "systemctl reboot",
  "text": "Reboot",
  "keybind": "r"
},
{
  "label": "shutdown",
  "action": "systemctl poweroff",
  "text": "Shutdown",
  "keybind": "s"
},
{
  "label": "suspend",
  "action": "systemctl suspend",
  "text": "Suspend",
  "keybind": "u"
}
